# ==============================================================
# DivinAds — Configuración del servidor OAuth / Marketing API
# ==============================================================
# Copia este archivo a `.env` y rellena los valores reales.
# NUNCA subas `.env` al repo (ya está en .gitignore).
# --------------------------------------------------------------

# ── Meta / Facebook App ───────────────────────────────────────
# Obtén estos valores en https://developers.facebook.com/apps/
# Settings → Basic
FB_APP_ID=
FB_APP_SECRET=

# Versión de Graph API a usar. Actualizar ~cada 12 meses.
# Ver: https://developers.facebook.com/docs/graph-api/changelog
FB_API_VERSION=v20.0

# ── OAuth redirect ────────────────────────────────────────────
# Debe coincidir EXACTAMENTE con la URL registrada en la app de Meta
# (Facebook Login for Business → Settings → Valid OAuth Redirect URIs).
# Desarrollo:
FB_REDIRECT_URI=http://localhost:8080/api/oauth/callback
# Producción (ejemplo): https://app.divinads.com/api/oauth/callback

# ── Scopes solicitados al usuario en el consent screen ────────
# Separados por coma, sin espacios.
# Pedir el mínimo necesario (Meta revisa cada permiso en App Review).
FB_OAUTH_SCOPES=ads_management,ads_read,business_management,pages_show_list,pages_read_engagement,pages_manage_metadata,read_insights,public_profile,email

# ── Servidor local ────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── Seguridad ─────────────────────────────────────────────────
# String aleatorio para firmar el parámetro `state` del OAuth
# (protección contra CSRF en el callback). Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_STATE_SECRET=

# Clave para encriptar los tokens en reposo en el token-store.
# Genera uno con el mismo comando.
TOKEN_ENCRYPTION_KEY=

# ── Opcional: logging ─────────────────────────────────────────
LOG_LEVEL=info
# Valores: error | warn | info | debug
