{
  "manifest_version": 3,
  "name": "DivinAds — Facebook Business Manager",
  "short_name": "DivinAds",
  "version": "2.0.0",
  "description": "Gestión profesional de Facebook Business Manager, Cuentas de Anuncios y Páginas mediante la Marketing API oficial de Meta.",
  "author": "DivinAds Team",

  "icons": {
    "16":  "img/favicon.png",
    "48":  "img/favicon.png",
    "128": "img/favicon.png"
  },

  "action": {
    "default_icon": {
      "16":  "img/favicon.png",
      "48":  "img/favicon.png"
    },
    "default_title": "DivinAds",
    "default_popup": "index.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],

  "host_permissions": [
    "http://localhost:8080/*",
    "https://localhost:8080/*"
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "index.html",
        "connect.html",
        "dashboard.html",
        "bm.html",
        "ads.html",
        "page.html",
        "pixel.html",
        "advantage.html",
        "attribution.html",
        "img/*",
        "css/*",
        "js/*",
        "fonts/*",
        "public/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' http://localhost:8080 https://localhost:8080"
  },

  "externally_connectable": {
    "matches": [
      "http://localhost:*/*",
      "https://localhost:*/*"
    ]
  },

  "minimum_chrome_version": "114"
}
