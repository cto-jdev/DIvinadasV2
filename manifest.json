{
  "manifest_version": 3,
  "name": "DivinAds — Facebook Business Manager",
  "short_name": "DivinAds",
  "version": "1.0.0",
  "description": "Gestión profesional de Facebook Business Manager, Cuentas de Anuncios y Páginas con IA integrada.",
  "author": "DivinAds Team",

  "icons": {
    "16":  "img/favicon.png",
    "48":  "img/favicon.png",
    "128": "img/favicon.png"
  },

  "action": {
    "default_icon": {
      "16":  "img/favicon.png",
      "48":  "img/favicon.png"
    },
    "default_title": "DivinAds",
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://business.facebook.com/*",
        "https://adsmanager.facebook.com/*"
      ],
      "js": ["js/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "*://*.facebook.com/*",
    "https://business.facebook.com/*",
    "https://adsmanager.facebook.com/*",
    "https://graph.facebook.com/*",
    "https://upload.facebook.com/*",
    "https://api.anthropic.com/*"
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "index.html",
        "bm.html",
        "ads.html",
        "page.html",
        "clone.html",
        "setting.html",
        "fb-connect.html",
        "phoi.html",
        "viewBm.html",
        "viewAds.html",
        "viewPage.html",
        "img/*",
        "css/*",
        "js/*",
        "fonts/*",
        "public/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "externally_connectable": {
    "matches": [
      "http://localhost:*/*",
      "https://localhost:*/*"
    ]
  },

  "minimum_chrome_version": "114"
}
