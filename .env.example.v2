# =====================================================================
# DivinAds V2 — Variables de entorno para apps/web (Vercel)
# Copiar a .env.local para desarrollo local.
# NUNCA subir al repositorio.
# =====================================================================

# ── Supabase ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Meta / Facebook ───────────────────────────────────────────────────
FB_APP_ID=<facebook-app-id>
FB_APP_SECRET=<facebook-app-secret>
FB_API_VERSION=v20.0
FB_REDIRECT_URI=https://app.divinads.com/api/meta/callback
FB_OAUTH_SCOPES=ads_management,ads_read,business_management,pages_show_list,pages_read_engagement,pages_manage_metadata,read_insights,public_profile,email

# ── Seguridad ─────────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_STATE_SECRET=<hex-64-chars>
JWT_SECRET=<hex-64-chars>
CRON_SECRET=<hex-32-chars>

# ── Upstash Redis (rate limiting) ─────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://<id>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>

# ── Stripe (Fase 7 — facturación) ─────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Sentry (observabilidad, opcional) ────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ── Entorno ───────────────────────────────────────────────────────────
NODE_ENV=development
# En Vercel se configura automáticamente (preview/production)
