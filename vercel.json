{
    "buildCommand": "cd apps/web && pnpm build",
    "outputDirectory": "apps/web/.next",
    "installCommand": "npm install -g pnpm@10.7.0 && pnpm install",
    "framework": "nextjs",
    "crons": [
        {
            "path": "/api/cron/refresh-tokens",
            "schedule": "0 3 * * *"
        },
        {
            "path": "/api/cron/purge-expired",
            "schedule": "0 4 * * 0"
        }
    ]
}
